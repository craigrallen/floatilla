# Server port
PORT=3100

# JWT secret — generate a strong random string for production
JWT_SECRET=change-me-to-a-random-secret

# JWT token expiry (default: 30 days)
JWT_EXPIRY=30d

# SQLite database file path
DB_PATH=./fleet-social.db

# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGINS=*

# ── Stripe Billing ────────────────────────────────────────────────────────────
# Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook signing secret (whsec_...) — from Stripe Dashboard > Webhooks
# Leave blank to skip signature verification (dev only)
STRIPE_WEBHOOK_SECRET=whsec_...

# App URL used as fallback return_url in billing portal
APP_URL=https://floatilla.app
